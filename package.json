{
  "name": "health-bridge",
  "version": "0.1.0",
  "description": "Pulls Fitbit Air data (incl. HRV) from the Google Health API and serves a clean JSON feed for an Apple Shortcut to write into Apple Health.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "fastify": "^4.28.1",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
