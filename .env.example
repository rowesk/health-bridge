# ---- Server ----
PORT=8080
PUBLIC_BASE_URL=https://health-bridge.yourdomain.com

# ---- Google OAuth (from Google Cloud Console) ----
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
GOOGLE_REDIRECT_URI=https://health-bridge.yourdomain.com/auth/callback
# Space-separated; must match the scopes you enabled on the OAuth consent screen.
GOOGLE_SCOPES=https://www.googleapis.com/auth/googlehealth.health_metrics_and_measurements.readonly https://www.googleapis.com/auth/googlehealth.sleep.readonly https://www.googleapis.com/auth/googlehealth.activity_and_fitness.readonly

# ---- Secrets (generate with: openssl rand -hex 32) ----
# Sent by the Apple Shortcut as "Authorization: Bearer <SHORTCUT_TOKEN>"
SHORTCUT_TOKEN=replace-with-long-random-string
# Protects /auth/start so only you can trigger the OAuth flow
ADMIN_TOKEN=replace-with-another-long-random-string
# Token Google sends in the webhook Authorization header (future use). Defaults to SHORTCUT_TOKEN if unset.
WEBHOOK_TOKEN=

# ---- Behaviour ----
# Your timezone — used to bucket "civil days" and to pick the sleep midpoint timestamp.
USER_TZ=Europe/London
# How many days back the scheduler re-pulls each run, to catch Fitbit's late revisions.
LOOKBACK_DAYS=4
# Path to the SQLite DB (keep on the mounted /data volume).
SQLITE_PATH=/data/health-bridge.db
# Set to 1 to log raw Google API data points (use once to verify field paths, then turn off).
DEBUG_DUMP=0
# Run a sync once on startup (handy after deploy). 0 to disable.
SYNC_ON_BOOT=1
# Sync steps + distance too. These DUPLICATE what the iPhone already logs natively,
# so leave at 0 unless the Air is your only step source (avoids double-counting).
SYNC_ACTIVITY=1
